// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model AuditLog {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  companyId   BigInt?  @map("company_id") @db.BigInt
  actorUserId BigInt?  @map("actor_user_id") @db.BigInt
  entity      String   @db.VarChar(100)
  entityId    BigInt?  @map("entity_id") @db.BigInt
  action      String   @db.VarChar(50)
  diff        Json?    @db.Json
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  company   Company? @relation(fields: [companyId], references: [id])
  actorUser User?    @relation("AuditLogActor", fields: [actorUserId], references: [id])

  @@index([companyId, createdAt], name: "idx_audit_company")
  @@index([entity, entityId], name: "idx_audit_entity")
  @@map("audit_logs")
}

model Company {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(100)
  legalName   String?  @map("legal_name") @db.VarChar(200)
  countryCode String?  @map("country_code") @db.Char(2)
  timezone    String?  @default("UTC") @db.VarChar(64)
  plan        String?  @db.VarChar(50)
  status      String?  @default("active") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  companyUsers      CompanyUser[]
  departments       Department[]
  designations      Designation[]
  customFields      CustomField[]
  documentTypes     DocumentType[]
  roles             Role[]
  employeeDocuments EmployeeDocument[]
  auditLogs         AuditLog[]

  @@map("companies")
}

model User {
  id            BigInt    @id @default(autoincrement()) @db.BigInt
  email         String    @unique @db.VarChar(255)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  mfaEnabled    Boolean   @default(false) @map("mfa_enabled")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamp(0)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  companyUsers     CompanyUser[]
  auditLogsAsActor AuditLog[]    @relation("AuditLogActor")

  @@map("users")
}

model CompanyUser {
  id           BigInt    @id @default(autoincrement()) @db.BigInt
  companyId    BigInt    @map("company_id") @db.BigInt
  userId       BigInt    @map("user_id") @db.BigInt
  employeeCode String?   @map("employee_code") @db.VarChar(50)
  status       String?   @default("active") @db.VarChar(20)
  joinedAt     DateTime? @map("joined_at") @db.Date
  leftAt       DateTime? @map("left_at") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  company             Company              @relation(fields: [companyId], references: [id])
  user                User                 @relation(fields: [userId], references: [id])
  employeeProfile     EmployeeProfile?
  employeeAssignments EmployeeAssignment[]
  employeeDocuments   EmployeeDocument[]
  userRoles           UserRole[]
  assignedRoles       UserRole[]           @relation("AssignedBy")
  departmentHead      Department[]         @relation("DepartmentHead")
  managerAssignments  EmployeeAssignment[] @relation("EmployeeAssignmentManager")
  verifiedDocuments   EmployeeDocument[]   @relation("EmployeeDocumentVerifiedBy")

  @@unique([companyId, userId], name: "uq_company_user")
  @@unique([companyId, employeeCode], name: "uq_company_emp_code")
  @@index([companyId], name: "idx_cu_company")
  @@index([userId], name: "idx_cu_user")
  @@map("company_users")
}

model Permission {
  id          BigInt  @id @default(autoincrement()) @db.BigInt
  code        String  @unique @db.VarChar(100)
  module      String  @db.VarChar(50)
  description String? @db.Text

  // Relations
  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  companyId   BigInt   @map("company_id") @db.BigInt
  name        String   @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  company         Company          @relation(fields: [companyId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([companyId, name], name: "uq_role_company_name")
  @@index([companyId], name: "idx_roles_company")
  @@map("roles")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  // Relations
  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  companyUserId BigInt   @map("company_user_id")
  roleId        BigInt   @map("role_id")
  assignedAt    DateTime @default(now()) @map("assigned_at") @db.Timestamp(0)
  assignedBy    BigInt?  @map("assigned_by") @db.BigInt

  // Relations
  companyUser    CompanyUser  @relation(fields: [companyUserId], references: [id])
  role           Role         @relation(fields: [roleId], references: [id])
  assignedByUser CompanyUser? @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@id([companyUserId, roleId])
  @@map("user_roles")
}

model Department {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  companyId BigInt   @map("company_id") @db.BigInt
  name      String   @db.VarChar(100)
  code      String?  @db.VarChar(20)
  parentId  BigInt?  @map("parent_id") @db.BigInt
  headId    BigInt?  @map("head_id") @db.BigInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  company             Company              @relation(fields: [companyId], references: [id])
  parent              Department?          @relation("DepartmentParent", fields: [parentId], references: [id])
  children            Department[]         @relation("DepartmentParent")
  head                CompanyUser?         @relation("DepartmentHead", fields: [headId], references: [id])
  employeeAssignments EmployeeAssignment[]

  @@unique([companyId, name], name: "uq_dept_company_name")
  @@index([companyId], name: "idx_dept_company")
  @@index([parentId], name: "idx_dept_parent")
  @@map("departments")
}

model Designation {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  companyId BigInt   @map("company_id") @db.BigInt
  title     String   @db.VarChar(100)
  level     Int?     @db.Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  company             Company              @relation(fields: [companyId], references: [id])
  employeeAssignments EmployeeAssignment[]

  @@unique([companyId, title], name: "uq_designation_company_title")
  @@map("designations")
}

model EmployeeProfile {
  companyUserId         BigInt    @id @map("company_user_id") @db.BigInt
  firstName             String    @map("first_name") @db.VarChar(100)
  middleName            String?   @map("middle_name") @db.VarChar(100)
  lastName              String    @map("last_name") @db.VarChar(100)
  dob                   DateTime? @db.Date
  gender                String?   @db.VarChar(20)
  maritalStatus         String?   @map("marital_status") @db.VarChar(20)
  bloodGroup            String?   @map("blood_group") @db.VarChar(5)
  personalEmail         String?   @map("personal_email") @db.VarChar(255)
  personalPhone         String?   @map("personal_phone") @db.VarChar(20)
  emergencyContactName  String?   @map("emergency_contact_name") @db.VarChar(150)
  emergencyContactPhone String?   @map("emergency_contact_phone") @db.VarChar(20)
  addressLine1          String?   @map("address_line1") @db.VarChar(200)
  addressLine2          String?   @map("address_line2") @db.VarChar(200)
  city                  String?   @db.VarChar(100)
  state                 String?   @db.VarChar(100)
  country               String?   @db.VarChar(100)
  postalCode            String?   @map("postal_code") @db.VarChar(20)
  photoUrl              String?   @map("photo_url") @db.Text
  extraData             Json?     @map("extra_data") @db.Json
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  companyUser CompanyUser @relation(fields: [companyUserId], references: [id])

  @@index([extraData], name: "idx_profile_extra")
  @@map("employee_profiles")
}

model EmployeeAssignment {
  id             BigInt    @id @default(autoincrement()) @db.BigInt
  companyUserId  BigInt    @map("company_user_id") @db.BigInt
  departmentId   BigInt?   @map("department_id") @db.BigInt
  designationId  BigInt?   @map("designation_id") @db.BigInt
  managerId      BigInt?   @map("manager_id") @db.BigInt
  employmentType String?   @map("employment_type") @db.VarChar(30)
  workLocation   String?   @map("work_location") @db.VarChar(100)
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  isCurrent      Boolean   @default(true) @map("is_current")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  companyUser CompanyUser  @relation(fields: [companyUserId], references: [id])
  department  Department?  @relation(fields: [departmentId], references: [id])
  designation Designation? @relation(fields: [designationId], references: [id])
  manager     CompanyUser? @relation("EmployeeAssignmentManager", fields: [managerId], references: [id])

  @@index([companyUserId, isCurrent], name: "idx_assign_current")
  @@index([companyUserId], name: "idx_assign_company")
  @@index([isCurrent], name: "idx_assign_current_flag")
  @@map("employee_assignments")
}

model CustomField {
  id         BigInt   @id @default(autoincrement()) @db.BigInt
  companyId  BigInt   @map("company_id") @db.BigInt
  entity     String   @db.VarChar(50)
  fieldKey   String   @map("field_key") @db.VarChar(100)
  fieldLabel String   @map("field_label") @db.VarChar(150)
  fieldType  String   @map("field_type") @db.VarChar(30)
  options    Json?    @db.Json
  isRequired Boolean  @default(false) @map("is_required")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, entity, fieldKey], name: "uq_custom_field")
  @@map("custom_fields")
}

model DocumentType {
  id         BigInt   @id @default(autoincrement()) @db.BigInt
  companyId  BigInt?  @map("company_id") @db.BigInt
  name       String   @db.VarChar(100)
  category   String?  @db.VarChar(50)
  isRequired Boolean  @default(false) @map("is_required")
  hasExpiry  Boolean  @default(false) @map("has_expiry")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  company           Company?           @relation(fields: [companyId], references: [id])
  employeeDocuments EmployeeDocument[]

  @@map("document_types")
}

model EmployeeDocument {
  id             BigInt    @id @default(autoincrement()) @db.BigInt
  companyId      BigInt    @map("company_id") @db.BigInt
  companyUserId  BigInt    @map("company_user_id") @db.BigInt
  documentTypeId BigInt?   @map("document_type_id") @db.BigInt
  fileName       String?   @map("file_name") @db.VarChar(255)
  fileUrl        String    @map("file_url") @db.Text
  fileSize       BigInt?   @map("file_size") @db.BigInt
  mimeType       String?   @map("mime_type") @db.VarChar(100)
  documentNumber String?   @map("document_number") @db.VarChar(100)
  issuedDate     DateTime? @map("issued_date") @db.Date
  expiryDate     DateTime? @map("expiry_date") @db.Date
  verified       Boolean   @default(false)
  verifiedBy     BigInt?   @map("verified_by") @db.BigInt
  verifiedAt     DateTime? @default(now()) @updatedAt @map("verified_at") @db.Timestamp(0)
  uploadedAt     DateTime  @default(now()) @map("uploaded_at") @db.Timestamp(0)

  // Relations
  company        Company       @relation(fields: [companyId], references: [id])
  companyUser    CompanyUser   @relation(fields: [companyUserId], references: [id])
  documentType   DocumentType? @relation(fields: [documentTypeId], references: [id])
  verifiedByUser CompanyUser?  @relation("EmployeeDocumentVerifiedBy", fields: [verifiedBy], references: [id])

  @@index([companyId], name: "idx_doc_company")
  @@index([companyUserId], name: "idx_doc_emp")
  @@map("employee_documents")
}
